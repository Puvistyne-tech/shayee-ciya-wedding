# Copy to .env.local and fill in your values.
# Web3Forms free plan requires client-side submission (NEXT_PUBLIC_ prefix).
# Create your access key at https://web3forms.com using ciyaraja@gmail.com
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Public URL of the deployed site (required for WhatsApp / iMessage link previews).
NEXT_PUBLIC_SITE_URL=https://sayeeciya.netlify.app
